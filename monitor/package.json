{
  "name": "monitor",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "firebase:deploy:firestore": "firebase deploy --only firestore",
    "firebase:deploy:functions": "firebase deploy --only functions",
    "functions:install": "npm install --prefix functions",
    "firebase:web-config": "firebase apps:sdkconfig WEB",
    "firebase:pull-web-config": "node scripts/pull-firebase-web-config.mjs",
    "admin:install": "npm install --prefix admin",
    "admin:init": "npm run init --prefix admin",
    "admin:create-default": "node admin/create-default-admin.mjs",
    "admin:seed:dz": "node admin/seed-algeria.mjs",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@firebase/firestore": "^4.13.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^12.11.0",
    "input-otp": "^1.4.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.5",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.15.4",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
