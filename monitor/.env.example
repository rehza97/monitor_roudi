# Copiez ce fichier vers .env et remplacez les valeurs par celles de
# Firebase Console → Paramètres du projet → Vos applications → Application Web.
# Alternative : copiez firebase.client.example.json vers firebase.client.json
# (objet firebaseConfig JSON) puis redémarrez npm run dev.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=roudi-monitor-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=roudi-monitor-app
VITE_FIREBASE_STORAGE_BUCKET=roudi-monitor-app.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
